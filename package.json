{
  "name": "@easemob/docs-mcp",
  "version": "1.0.0",
  "description": "环信文档搜索服务 - 支持多平台文档搜索和SSE流式响应",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "easemob-doc-search": "dist/cli.js",
    "@easemob/docs-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "start:dev": "nodemon",
    "prepublishOnly": "npm run build",
    "mcp": "node dist/mcp-server.js",
    "mcp:dev": "ts-node src/mcp-server.ts",
    "mcp-client": "node dist/mcp-client.js",
    "mcp-client:dev": "ts-node src/mcp-client.ts",
    "mcp-remote": "EASEMOB_API_URL=${EASEMOB_REMOTE_URL:-http://localhost:8000} node dist/mcp-client.js",
    "mcp-remote:dev": "EASEMOB_API_URL=${EASEMOB_REMOTE_URL:-http://localhost:8000} ts-node src/mcp-client.ts",
    "setup-cursor": "node scripts/setup-cursor.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "easemob",
    "documentation",
    "search",
    "sse",
    "streaming",
    "api",
    "mcp",
    "cursor",
    "model-context-protocol"
  ],
  "author": "Easemob",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/easemob/easemob-doc-search.git"
  },
  "bugs": {
    "url": "https://github.com/easemob/easemob-doc-search/issues"
  },
  "homepage": "https://github.com/easemob/easemob-doc-search#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "commander": "^11.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.10",
    "helmet": "^7.1.0",
    "node-fetch": "^3.3.2",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.8.0",
    "@types/node-fetch": "^2.6.4",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "scripts"
  ],
  "publishConfig": {
    "access": "public"
  }
}
