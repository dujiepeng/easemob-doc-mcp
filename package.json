{
  "name": "easemob-doc-search",
  "version": "1.0.0",
  "description": "环信文档搜索服务 - 支持多平台文档搜索和SSE流式响应",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "easemob-doc-search": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "install-deps": "pip install -r requirements.txt"
  },
  "keywords": [
    "easemob",
    "documentation",
    "search",
    "sse",
    "streaming",
    "api"
  ],
  "author": "Easemob",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/easemob/easemob-doc-search.git"
  },
  "bugs": {
    "url": "https://github.com/easemob/easemob-doc-search/issues"
  },
  "homepage": "https://github.com/easemob/easemob-doc-search#readme",
  "dependencies": {
    "node-fetch": "^3.3.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/node-fetch": "^2.6.4",
    "typescript": "^5.2.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "requirements.txt",
    "fastmcp_server"
  ]
} 